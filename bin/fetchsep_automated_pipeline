###### IDSEP Arguments #######
parser.add_argument("--kurtosis_cut", type=float, default=None,
        help=("Set IDSEP kurtosis_cut quality reqirement. Data distributions with kurtosis > kurtosis_cut "
            "will be excluded from calculating mean background. Some native experiments have a "
            "predefined kurtosis_cut value in experiments.py. Set a value here to override. "
            "Will default to values in experiments.py or fetchsep.cfg."))

parser.add_argument("--idsep_nsigma", type=float, default=None,
        help=("Set idsep_nsigma to indicate the number of sigma above background required to "
            "identify an enhancement: fluxes > mean + idsep_nsigma*sigma. "
            "Will default to value in fetchsep.cfg."))

parser.add_argument("--init_win", type=float, default=None,
        help=("Set IDSEP init_win to indicate the length of the averaging window used "
            "in the first rough calculation of the mean background. Recommend >=30 days. "
            "Often use 150 days. Will default to value in fetchsep.cfg."))

parser.add_argument("--sliding_win", type=float, default=None,
        help=("Set IDSEP sliding_win to indicate the length of the averaging window used "
            "to calculate the refined daily mean background. A backward-smoothing window "
            "of 5 up to 27 days works well. Will default to value in fetchsep.cfg."))
            
parser.add_argument("--percent_points", type=float, default=None,
        help=("Set IDSEP percent_points from 0 to 1.0 to determine the number of points "
            "that must be considered background in the sliding window in order to calculate "
            "the mean background, intended to avoid mean and sigma calculation from too few "
            "points. It may be desireable to change the percent of points required in the "
            "background window depending on window length. "
            "percent_points = 0.4 works well for a 5-day sliding_win. "
            "Will default to value in fetchsep.cfg."))


####### OpSEP Arguments #####
parser.add_argument("--Threshold", type=str, default="",
        help=("An additional energy and flux thresholds "
                "(written as 100,1 with no spaces) which will be "
                "used to define the event. e.g. 100,1 indicates "
                ">100 MeV fluxes crossing 1 pfu (1/[cm^2 s sr]). "
                "Multiple thresholds may be written as \"30,1;50,1\" "
                "separated by a semi-colon."))

parser.add_argument("--Associations",
        help=("Set flag to associate flare, CME, radio, etc information "
            "if an SEP event is found in the data. "), action="store_true")

parser.add_argument("--opsep_nsigma", type=float, default=None,
        help=("Set opsep_nsigma to indicate the number of sigma above background required to "
            "identify an enhancement: fluxes > mean + opsep_nsigma*sigma. "
            "Will default to value in fetchsep.cfg."))


#parser.add_argument("--UMASEP",
#        help=("Set flag to calculate flux values and thresholds "
#                "specific to the UMASEP model. Thresholds for >10, >30, "
#                ">50, >100 MeV and flux values at 3, 4, 5, 6, 7 hours "
#                "after crossing thresholds."), action="store_true")

parser.add_argument("--JSONType", type=str, choices=['model',
        'observations'], default='observations',
        help=("For user-input files, specify whether they are observations "
        "or model predictions to generate a JSON file in the correct format. "
        "Choices are \"model\" or \"observations\" Default is observations."))

parser.add_argument("--Location", type=str, default='earth',
        help=("Location of time profile. CCMC json files recognize: mercury, venus, "
            "earth, mars, psp, stereoa, stereob, dawn, juno, L1, L2, L4, L5. You may "
            "enter another location if needed. Default = earth."))

parser.add_argument("--Species", type=str, default='proton',
        help=("Location of time profile. CCMC json files recognize: electron, proton, "
              " helium, helium3, helium4, oxygen, iron, ion. You may "
              "enter another location if needed. Default = proton"))


parser.add_argument("--IDSEPEnhancement",
        help="Set flag to use background mean+n*sigma found with IDSEP "
            "to identify SEP enhancement above background in OpSEP. ",
            action="store_true")

parser.add_argument("--IDSEPSubtractBG",
        help="Set flag to subtract the background from the "
            "SEP flux using the background found with IDSEP in OpSEP. ",
            action="store_true")


####### BATCH Arguments ######
#Batch file is a csv, but saved as a txt to avoid opening with excel
#which will mess up the date format if the user is not careful.
parser.add_argument("--BatchFile", type=str, default='batch_event_list.csv',
        help=("Specify the name of the batch file. Will create a new (or overwrite existing) "
                "batch file with this name if StartPoint set to IDSEP or MAKEFILE."
